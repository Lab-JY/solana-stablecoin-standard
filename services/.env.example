# ──────────────────────────────────────────────
# SSS Backend Services — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in required values.
#   cp .env.example .env

# ── Authentication (REQUIRED) ─────────────────
# Bearer token used by all services. Compared with constant-time equality.
# Generate a strong random value, e.g.: openssl rand -hex 32
API_SECRET_KEY=

# ── Solana RPC ────────────────────────────────
# JSON-RPC endpoint for on-chain reads/writes
RPC_URL=https://api.devnet.solana.com

# WebSocket endpoint for the indexer to subscribe to on-chain events
WS_URL=wss://api.devnet.solana.com

# ── Program ───────────────────────────────────
# Deployed SSS Token program ID
PROGRAM_ID=11111111111111111111111111111111

# Path to the payer/authority keypair JSON file
KEYPAIR_PATH=./keys/id.json

# ── Database ──────────────────────────────────
# SQLite connection string (shared across all services)
DATABASE_URL=sqlite:./data/sss.db

# ── Rate Limiting ─────────────────────────────
# Max requests per IP per window
RATE_LIMIT_MAX=100

# Window duration in seconds
RATE_LIMIT_WINDOW_SECS=60

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins (* to allow all)
ALLOWED_ORIGINS=http://localhost:3000

# ── Webhook ───────────────────────────────────
# Poll interval (seconds) for the webhook background worker
WEBHOOK_POLL_INTERVAL_SECS=5

# Internal URL the indexer uses to forward events to the webhook service
# In Docker Compose this defaults to http://webhook:3000
WEBHOOK_SERVICE_URL=http://webhook:3000

# ── Logging ───────────────────────────────────
# Rust log level filter (e.g. debug, info, info,tower_http=warn)
RUST_LOG=info
